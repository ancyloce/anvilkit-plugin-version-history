	"packageName": "@anvilkit/plugin-version-history",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/plugin-version-history\n\nHeadless version-history plugin for Anvilkit Studio.\n\n## What It Ships\n\n- "
		},
		{
			"kind": "code",
			"text": "`createVersionHistoryPlugin({ adapter, maxSnapshots })`"
		},
		{
			"kind": "text",
			"text": "\n- "
		},
		{
			"kind": "code",
			"text": "`inMemoryAdapter()`"
		},
		{
			"kind": "text",
			"text": " for tests\n- "
		},
		{
			"kind": "code",
			"text": "`localStorageAdapter({ namespace })`"
		},
		{
			"kind": "text",
			"text": " for demos\n- "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-version-history/testing`"
		},
		{
			"kind": "text",
			"text": " with "
		},
		{
			"kind": "code",
			"text": "`runAdapterContract()`"
		},
		{
			"kind": "text",
			"text": "\n\n## Status\n\nThis package is the phase5-011 scaffold. It contributes header actions\ntoday and defers the sidebar-panel slot wiring to phase5-013 once Core\nadds the sidebar registration API."
		}
	],
